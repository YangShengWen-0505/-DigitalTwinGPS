# Google Maps Directions API key
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Tailscale IP of this PC, usually 100.x.x.x
PC_TAILSCALE_IP="100.x.x.x"

# Tailscale IP of the Android phone running MacroDroid HTTP Server
PHONE_TAILSCALE_IP="100.x.x.x"

# Shared secret for task APIs and dashboard login.
# Use a long random value. Minimum accepted length is 16 characters.
API_SECRET_KEY="replace_with_a_long_random_secret"

# false: Flask serves HTTPS with adhoc SSL for local development.
# true : Flask binds to localhost HTTP and Caddy handles HTTPS.
USE_CADDY="false"

# Flask port
FLASK_PORT=5050

# Runtime timezone
TZ="Asia/Taipei"

# Movement speed multiplier. Higher values make simulated movement faster.
SPEED_MULTIPLIER=1

# Seconds between Guardian checks/resends. Minimum accepted value is 0.5.
GUARD_INTERVAL=1.5
