GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# ── Tailscale 網路設定 ──────────────────────────────────────────────
# 你的電腦的 Tailscale 虛擬 IP (100.x.x.x)，用於啟動訊息顯示正確的連線網址
PC_TAILSCALE_IP="100.x.x.x"

# 手機端 Tailscale 的虛擬 IP (100.x.x.x)，伺服器將 GPS 座標推送至此
PHONE_TAILSCALE_IP="100.x.x.x"

# ── API 安全設定 ────────────────────────────────────────────────────
# API 安全驗證權杖，需與 MacroDroid 發送時的 X-API-Key Header 一致
API_SECRET_KEY="your_secure_secret_key_here"

# ── 伺服器模式 ──────────────────────────────────────────────────────
# 生產環境：設為 true 則啟用 Caddy 反向代理模式 (Flask 僅監聽 localhost HTTP)
# 開發環境：設為 false (預設) 則使用 adhoc 自簽憑證
USE_CADDY="false"

# ── 系統進階設定 ────────────────────────────────────────────────────
# Flask 伺服器監聽 Port (預設 5050)
FLASK_PORT=5050

# 系統時區 (預設 Asia/Taipei)
TZ="Asia/Taipei"