# DigitalTwinGPS — Caddy Reverse Proxy 設定 (P4)
#
# 使用方式：
#   1. 安裝 Caddy: https://caddyserver.com/docs/install
#   2. 在 .env 中設定 USE_CADDY=true
#   3. 先啟動 Flask: python run_server.py
#   4. 再啟動 Caddy: caddy run --config Caddyfile
#
# Caddy 會自動申請 Let's Encrypt 憑證（需要對外 IP + 正式 Domain）
# 若在內網/Tailscale 使用，改用下方 tls internal 區段（自簽但受信任）

{
    # 全域設定：關閉自動 HTTPS 重新導向（可依需求開啟）
    # email your@email.com
}

# --- 選項 A：使用 Tailscale 或內網（自簽但受 Caddy 管理的憑證）---
# 綁定到具體 Tailscale IP（PC_TAILSCALE_IP），避免攔截伺服器上所有其他站點
100.127.146.60:443 {
    tls internal

    reverse_proxy localhost:5050

    log {
        output file logs/caddy_access.log
        format console
    }
}

# HTTP -> HTTPS 重新導向
:80 {
    redir https://{host}{uri} permanent
}

# --- 選項 B：有正式 Domain + Let's Encrypt（取消下方註解並填入 Domain）---
# your.domain.com {
#     reverse_proxy localhost:5000
# }
