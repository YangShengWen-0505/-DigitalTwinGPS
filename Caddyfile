# DigitalTwinGPS Caddy reverse proxy example.
#
# Usage:
# 1. Install Caddy.
# 2. Set USE_CADDY="true" in .env.
# 3. Start Flask with: python run_server.py
# 4. Start Caddy with: caddy run --config Caddyfile
#
# Replace <PC_TAILSCALE_IP> with this PC's Tailscale IP or use a trusted
# MagicDNS/domain name. Keep this service inside Tailscale or a trusted LAN.

{
    # Optional when using a public domain and Let's Encrypt.
    # email your@email.com
}

<PC_TAILSCALE_IP>:443 {
    tls internal

    reverse_proxy localhost:5050

    log {
        output file logs/caddy_access.log
        format console
    }
}

:80 {
    redir https://{host}{uri} permanent
}

# Public-domain example:
# your.domain.com {
#     reverse_proxy localhost:5050
# }
